<%- include('partials/head') %>
<body>
<%- include('partials/navbar') %>

<div class="container py-5">
  <h1 class="display-5 fw-bold mb-2 text-white">Meus Bots</h1>
  <p class="text-white-50 mb-5">Selecione o plano que deseja adquirir. Nossa equipe entrará em contato pelo WhatsApp para concluir.</p>

  <% if (locals.sucesso) { %>
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
      </svg>
      <%= locals.sucesso %>
    </div>
  <% } %>

  <% if (locals.erro) { %>
    <div class="alert alert-danger mb-4" role="alert"><%= locals.erro %></div>
  <% } %>

  <% if (locals.planoAtual) { %>
    <div class="alert alert-info mb-4">
      Plano atual: <strong><%= locals.planoAtual %></strong> — aguardando confirmação da equipe.
    </div>
  <% } %>

  <form method="POST" action="/meus-bots">
    <div class="row g-4">

      <% planos.forEach(function(p) { %>
        <div class="col-md-4">
          <label style="cursor:pointer;display:block;">
            <input type="radio" name="plano" value="<%= p.id %>" style="display:none;"
              onchange="this.closest('form').submit()"
              <%= (locals.planoAtual === p.id) ? 'checked' : '' %>
            >
            <div class="bot-card" style="position:relative; border: 2px solid <%= (locals.planoAtual === p.id) ? '#00c6ff' : 'transparent' %>;">
              <% if (locals.planoAtual === p.id) { %>
                <span style="position:absolute;top:12px;right:12px;background:#00c6ff;color:#000;font-size:0.75em;padding:2px 8px;border-radius:20px;font-weight:600;">Ativo</span>
              <% } %>
              <h3 class="gradient-text mb-2"><%= p.nome %></h3>
              <h4 class="mb-3"><%= p.preco %></h4>
              <p class="text-white-50" style="font-size:0.9em;">Clique para selecionar este plano.</p>
            </div>
          </label>
        </div>
      <% }) %>

    </div>
  </form>
</div>

<%- include('partials/footer') %>
</body>
